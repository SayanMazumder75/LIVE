# Frontend environment overrides for AI Transcriber (LIVE).
# Copy to `.env.local` (git-ignored) and edit per environment.

# WebSocket endpoint for the live transcription pipeline.
# Defaults to ws://localhost:8001 when unset.
# VITE_WS_URL=ws://localhost:8001

# HTTP endpoint for session persistence (start-session, push,
# transcripts, transcript/:id, upload-audio, insights).
# Defaults to http://localhost:8000 when unset.
# VITE_HTTP_URL=http://localhost:8000

# ── SSO bridge (auth.js) ───────────────────────────────────────────────
# Origin of the MeetMind parent window that broadcasts JWTs into this
# iframe. The auth bridge will ONLY accept tokens from this origin —
# any other origin's postMessage is silently ignored.
#
# Production:
#   VITE_MEETMIND_ORIGIN=https://meetmind.vercel.app
#
# Local development (MeetMind running on Next.js default port):
#   VITE_MEETMIND_ORIGIN=http://localhost:3000
#
# Escape hatch for local-network testing only — accepts tokens from
# every origin. NEVER ship a build with this.
#   VITE_MEETMIND_ORIGIN=*
# VITE_MEETMIND_ORIGIN=https://meetmind.vercel.app

# ── PiP host targeting (FloatingMicWidget) ─────────────────────────────
# Origin of the parent page that loads /meetmind-pip-host.js. Used as
# the target origin for postMessage delegation when the floating mic
# widget runs inside an iframe. Defaults to "*" if unset; set this in
# production for defence-in-depth.
# VITE_PARENT_ORIGIN=https://meetmind.vercel.app

# ── Tuning knobs ──────────────────────────────────────────────────────
# Hindi-mode silence-detection RMS threshold (default 0.01). Below this
# value a 4s window is considered silent and skipped.
# VITE_HINDI_SILENCE_RMS=0.01
