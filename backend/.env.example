# Copy to .env and fill in your real keys.
#
# AssemblyAI handles English speech-to-text.
# Free signup: https://www.assemblyai.com/dashboard/signup
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Groq handles Hindi text -> English translation (used by Hindi mode).
# Free signup: https://console.groq.com/keys
# Free tier is generous: ~30 RPM and ~14,400 requests/day on Llama models.
# Leave GROQ_API_KEY blank to disable translation entirely.
GROQ_API_KEY=
# Optional: defaults to llama-3.3-70b-versatile (multilingual, supports
# Hindi well). Other good choices: meta-llama/llama-4-scout-17b-16e-instruct,
# llama-3.1-8b-instant (faster, lower-quality).
GROQ_MODEL=
# Optional: Whisper model used for Hindi + System Audio mode. Defaults
# to whisper-large-v3 (highest accuracy). For lower latency at slightly
# lower accuracy, set this to whisper-large-v3-turbo.
WHISPER_MODEL=

# Optional: where the local WS server listens for browser clients.
WS_HOST=0.0.0.0
WS_PORT=8001

# Session persistence (ported from the old MeetMind project).
# Set MONGO_URI to a MongoDB Atlas / self-hosted URI to enable session
# history, /push, and /transcript/:session_id. Leave it blank to run
# the live transcription pipeline without any database — the four
# persistence routes will return 503 but everything else still works.
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=
# Optional: override the database name. If omitted, the database from
# the connection string is used, falling back to "meetmind" so old
# records remain accessible.
MONGO_DB=

# Optional: where the HTTP REST server listens. Used by the frontend
# for session start / push / load.
HTTP_HOST=0.0.0.0
HTTP_PORT=8000


# Audio recording (Cloudinary). When all three are set, every saved
# session also stores a downloadable recording of the meeting on
# Cloudinary, surfaced in the saved-session view as a styled audio
# player + Download button. Free tier signup: https://cloudinary.com
# Leave them blank to keep transcription / insights working without
# recording — the /upload-audio route just returns 503 in that case.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
