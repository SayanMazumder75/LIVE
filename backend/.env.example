# Copy to .env and fill in your real key.
#
# Get a free AssemblyAI API key: https://www.assemblyai.com/dashboard/signup
# The free tier includes credits that work with Universal-Streaming.

ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Optional: enable Hindi -> English translation of finalized transcripts.
# Get a free Gemini API key: https://aistudio.google.com/app/apikey
# Leave GEMINI_API_KEY blank to disable translation entirely.
GEMINI_API_KEY=
# Optional: defaults to gemini-2.5-flash-lite (15 RPM / 1000 RPD on the
# free tier). Other good choices: gemini-2.5-flash, gemini-2.5-pro.
GEMINI_MODEL=

# Optional: where the local WS server listens for browser clients.
WS_HOST=0.0.0.0
WS_PORT=8001
